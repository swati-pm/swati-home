FROM node:22-alpine AS build
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci
COPY . .

ARG VITE_GOOGLE_CLIENT_ID
ARG VITE_ADMIN_EMAIL
ARG VITE_API_BASE=/api
ARG VITE_SITE_NAME=Swati Aggarwal
ARG VITE_SITE_FIRST_NAME=Swati
ARG VITE_SESSION_KEY=swati-home-auth

ENV VITE_GOOGLE_CLIENT_ID=$VITE_GOOGLE_CLIENT_ID
ENV VITE_ADMIN_EMAIL=$VITE_ADMIN_EMAIL
ENV VITE_API_BASE=$VITE_API_BASE
ENV VITE_SITE_NAME=$VITE_SITE_NAME
ENV VITE_SITE_FIRST_NAME=$VITE_SITE_FIRST_NAME
ENV VITE_SESSION_KEY=$VITE_SESSION_KEY

RUN npm run build

FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html
COPY nginx.conf.template /etc/nginx/templates/default.conf.template
ENV BACKEND_HOST=server
ENV NGINX_ENVSUBST_FILTER=BACKEND_HOST
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
